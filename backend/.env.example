# Porta del server (Render la imposta automaticamente in produzione)
PORT=3001

# Stringa lunga e casuale, usata per firmare i token JWT — non condividerla mai
JWT_SECRET=change_this_to_a_long_random_string

# Turso (libSQL) — ottenuti con: turso db show giulivo-db --url / turso db tokens create giulivo-db
TURSO_DATABASE_URL=libsql://giulivo-db-tuoaccount.turso.io
TURSO_AUTH_TOKEN=il_tuo_token_turso

# Resend — https://resend.com (per le email di conferma prenotazione)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=Giulivo <prenotazioni@giulivovicopisano.it>
RESTAURANT_NOTIFY_EMAIL=indirizzo-del-ristorante@example.com

# Domini autorizzati a chiamare l'API (separati da virgola, niente slash finale)
CORS_ORIGIN=https://giulivovicopisano.it,https://www.giulivovicopisano.it
